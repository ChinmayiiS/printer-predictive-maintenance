from fastapi import FastAPI
import mlflow.pyfunc

app = FastAPI()

model = mlflow.pyfunc.load_model("models:/printer_xgb_model/Production")

@app.get("/")
def home():
    return {"message": "Printer Prediction API"}

@app.post("/predict")
def predict(data: dict):
    features = [[
        data["temperature"],
        data["print_count"],
        data["error_count"],
        data["toner_level"],
        data["usage_intensity"]
    ]]

    prediction = model.predict(features)

    return {"prediction": int(prediction[0])}
